PORT=3001
KEYCLOAK_BASE_URL=http://localhost:8080
KEYCLOAK_ISSUER=http://localhost:8080/realms/docvault
KEYCLOAK_REALM=docvault
KEYCLOAK_AUDIENCE=docvault-gateway

DATABASE_URL="postgresql://docvault:docvaultpw@localhost:5432/docvault_metadata?schema=public"
AUDIT_SERVICE_URL=http://localhost:3004
DOWNLOAD_GRANT_SECRET=docvault-download-grant-secret

# ── Notification: approver lookup via Keycloak Admin API ───────────────────
# On every document submit, metadata-service queries Keycloak to find all users
# with role 'approver' or 'admin' so they can receive notifications.
#
# This block uses the admin account (from docker-compose infra/.env).
# When absent: getApprovers() returns { userIds: [] } — workflow still works,
# approvers just don't get in-app notifications.
#
# REQUIRED: Docker infra must be running (Keycloak must be reachable at
# KEYCLOAK_BASE_URL). The admin account lives in the master realm and has
# permission to query the docvault realm via admin-cli.
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=adminpw
